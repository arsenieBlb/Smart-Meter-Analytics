POSTGRES_DB=smart_utility
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_SCHEMA=utility

LOAD_TO_POSTGRES=false
API_AUTO_LOAD_DATA=true

NUM_CUSTOMERS=1000
NUM_METERS=1200
START_DATE=2025-01-01
END_DATE=2025-12-31
