MISSING_READING_RATE=0.035
DUPLICATE_READING_RATE=0.0075
ANOMALY_RATE=0.015
INACTIVE_METER_RATE=0.04
ESTIMATED_READING_RATE=0.06
DELAYED_READING_RATE=0.03

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
